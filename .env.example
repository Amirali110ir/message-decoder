DATABASE_URL=sqlite:///./message_decoder.db
AI_PROVIDER=mock
AI_MODEL_VERSION=mock-v0.1
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
# Free layer: cheap/fast model for light analysis (lens/risk classification)
AI_FREE_MODEL=google/gemini-2.5-flash-lite
# Paid layer: higher-quality model for the final, natural-Persian reply
AI_PAID_MODEL=google/gemini-3.1-flash-lite
# Generation quality knobs (paid kept low/stable, free a bit higher)
AI_PAID_TEMPERATURE=0.4
AI_FREE_TEMPERATURE=0.6
# Paid self-critique pass: "true" = best quality (~2x paid latency),
# "false" = faster/cheaper (forbidden phrases are still scrubbed either way)
AI_PAID_SELF_CRITIQUE_ENABLED=true
OTP_PROVIDER=mock
DEV_OTP_CODE=123456
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
SIGNUP_BONUS_CREDITS=5
# --- SMS.ir ---
SMSIR_API_KEY=
SMSIR_METHOD=auto
SMSIR_TEMPLATE_ID=
SMSIR_PARAMETER_NAME=Code
SMSIR_LINE_NUMBER=
SMSIR_MESSAGE_TEMPLATE=رمزگشایی از خطوط پنهان پیام.\n\nکلید ورود به دکودر: {code}
# If SMSIR_TEMPLATE_ID is empty, SMSIR_METHOD=auto uses bulk send with SMSIR_LINE_NUMBER.
# SMS.ir approved verify template copy:
# رمزگشایی از خطوط پنهان پیام.
#
# کلید ورود به دکودر: #Code#

# --- Kavenegar (جایگزین SMS.ir) ---
KAVENEGAR_API_KEY=
# verify_lookup → استفاده از قالب تایید (نیاز به KAVENEGAR_TEMPLATE)
# send → ارسال پیامک معمولی (نیاز به KAVENEGAR_SENDER)
KAVENEGAR_METHOD=verify_lookup
KAVENEGAR_TEMPLATE=
KAVENEGAR_SENDER=
KAVENEGAR_TYPE=sms
KAVENEGAR_MESSAGE_TEMPLATE=رمزگشایی از خطوط پنهان پیام.\n\nکلید ورود به دکودر: {code}

JWT_SECRET=change-me-in-production
ADMIN_TOKEN=change-me-admin-token
ADMIN_PHONE=
ADMIN_PASSWORD=change-this-password
ZARINPAL_MERCHANT_ID=sandbox
ZARINPAL_CALLBACK_URL=http://localhost:3000/payment/callback

# --- Telegram bot + OTP bridge ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# secret مشترک بین Liara API ↔ Vercel function ↔ Cloudflare Worker
# بدون این، مسیر Telegram OTP کاملاً غیرفعال است.
TELEGRAM_BRIDGE_SECRET=
NEXT_PUBLIC_TELEGRAM_WORKER_URL=https://message-decoder-telegram.shabestani-am.workers.dev
# اگر خالی باشد، frontend از window.location.origin استفاده می‌کند.
NEXT_PUBLIC_TELEGRAM_OTP_RELAY_URL=

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Vercel web + Liara API example:
# NEXT_PUBLIC_API_URL=https://message-decoder-py.liara.run
# ZARINPAL_CALLBACK_URL=https://YOUR_VERCEL_DOMAIN/payment/callback
# CORS_ORIGINS=https://YOUR_VERCEL_DOMAIN,https://message-decoder-py.liara.run,http://localhost:3000,http://127.0.0.1:3000
